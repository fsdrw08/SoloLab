resize_rootfs: true

# https://cloudinit.readthedocs.io/en/latest/reference/modules.html#set-passwords
ssh_pwauth: true
# https://gist.github.com/wipash/81064e811c08191428002d7fe5da5ca7
# https://cloudinit.readthedocs.io/en/latest/reference/examples.html#yaml-examples
users:
  - name: admin
    uid: 1000
    gecos: admin
    groups: wheel
    plain_text_passwd: P@ssw0rd
    lock_passwd: false
    sudo: "ALL=(ALL) NOPASSWD:ALL"
    shell: /bin/bash
    ssh_import_id: None
    ssh_authorized_keys:
      - ssh-rsa  vagrant insecure public key
  - name: podmgr
    uid: 1001
    gecos: podmgr
    plain_text_passwd: podmgr
    lock_passwd: false
    shell: /bin/bash
    ssh_import_id: None
    ssh_authorized_keys:
      - ssh-rsa  vagrant insecure public key

