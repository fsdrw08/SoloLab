  - path: /home/admin/.bashrc
    permissions: "0644"
    owner: admin:admin
    defer: true
    content: |
      source /etc/profile.d/bash_completion.sh
  - path: ${custom_bin_dir}/consul_linux_amd64.zip
    permissions: "0644"
    source:
      uri: ${consul_download_url}
  - path: ${custom_bin_dir}/nomad_linux_amd64.zip
    permissions: "0644"
    source:
      uri: ${nomad_download_url}
  - path: ${custom_bin_dir}/nomad-driver-podman_linux_amd64.zip
    permissions: "0644"
    source:
      uri: ${nomad_podman_driver_download_url}
  - path: ${nomad_config_dir}/client.pem
    permissions: "0600"
    source:
      uri: ${nomad_client_cert_download_url}
      headers:
        Authorization: Basic ${nomad_client_cert_download_url_cred}
  - path: ${nomad_config_dir}/client-key.pem
    permissions: "0600"
    source:
      uri: ${nomad_client_cert_key_download_url}
      headers:
        Authorization: Basic ${nomad_client_cert_download_url_cred}
  # redhat family trust custom cert
  - path: ${custom_root_ca_path}/SoloLab-Root-CA.pem
    permissions: "0644"
    source:
      uri: ${custom_root_ca_url}
  - path: ${custom_root_ca_path}/Consul-Root-CA.pem
    permissions: "0644"
    content: |
      ${indent(6, consul_ca_content)}
  - path: ${consul_config_dir}/consul.hcl
    permissions: "0644"
    content: |
      acl {
        enabled = true
        tokens {
          default = "${consul_acl_token}"
        }
      }
      auto_encrypt {
        tls = true
      }
      bind_addr = "{{ GetInterfaceIP \"eth0\" }}"
      client_addr = "127.0.0.1"
      data_dir = "${consul_data_dir}"
      encrypt = "${consul_encrypt_key}"
      ports {
        https = 8501
      }
      retry_join = ["${consul_server_fqdn}"]
      server = false
      tls {
        defaults {
          ca_file = "${custom_root_ca_path}/SoloLab-Root-CA.pem"
          verify_incoming = false
          verify_outgoing = true
          verify_server_hostname = true
        }
        internal_rpc {
          verify_server_hostname = true
        }
      }
  - path: /etc/systemd/system/consul.service
    permissions: "0644"
    content: |
      [Unit]
      Description="HashiCorp Consul - A service mesh solution"
      Documentation=https://developer.hashicorp.com/
      After=network-online.target
      Wants=network-online.target.service
      ConditionFileNotEmpty=${custom_bin_dir}/consul
      ConditionFileNotEmpty=${consul_config_dir}/consul.hcl
      ConditionPathIsDirectory=${consul_data_dir}
      Before=umount.target
      Conflicts=umount.target

      [Service]
      ExecStart=${custom_bin_dir}/consul agent \
        -config-dir=${consul_config_dir}
      ExecReload=/bin/kill --signal HUP $MAINPID
      KillMode=process
      KillSignal=SIGTERM
      Restart=on-failure
      LimitNOFILE=65536

      [Install]
      WantedBy=multi-user.target
  - path: ${nomad_config_dir}/nomad.hcl
    permissions: "0644"
    content: |
      client {
        enabled = true
        servers = ["${nomad_server_fqdn}"]
        drain_on_shutdown {
          deadline           = "20s"
          ignore_system_jobs = true
        }
      }

      consul {
        address = "127.0.0.1:8501"
        ca_file = "${custom_root_ca_path}/Consul-Root-CA.pem"
        ssl = true
        token = "${nomad_consul_acl_token}"
      }

      data_dir           = "${nomad_data_dir}"
      leave_on_interrupt = true
      leave_on_terminate = true

      ports {
        http = 4646
        rpc  = 4647
        serf = 4648
      }

      tls {
        http = true
        rpc  = true
        ca_file   = "${custom_root_ca_path}/SoloLab-Root-CA.pem"
        cert_file = "${nomad_config_dir}/client.pem"
        key_file  = "${nomad_config_dir}/client-key.pem"
        # verify_server_hostname = true
        verify_https_client = true
      }

      plugin "docker" {
        config {
          endpoint = "unix:///disable/docker.sock"
        }
      }

      # plugin "docker" {
      #   config {
      #     allow_privileged = true
      #     infra_image = "zot.day0.sololab/pause-amd64:3.3"
      #     volumes {
      #       enabled      = true
      #       selinuxlabel = "z"
      #     }
      #   }
      # }

      # Podman driver plugin configuration
      # Reference: https://developer.hashicorp.com/nomad/plugins/drivers/podman#plugin-options
      plugin "nomad-driver-podman" {
        config {
          socket { 
            name        = "default"
            socket_path = "unix://run/podman/podman.sock"
          }
          volumes {
            enabled = true
            selinuxlabel = "z"
          }
        }
      }

      plugin "raw_exec" {
        config {
          enabled = true
        }
      }

      plugin_dir = "${custom_bin_dir}"

      vault {
        enabled = true
        address = "${vault_server_address}"
        ca_file = "${custom_root_ca_path}/SoloLab-Root-CA.pem"
        jwt_auth_backend_path = "jwt-nomad"
      }
  - path: /etc/systemd/system/nomad.service
    permissions: "0644"
    content: |
      [Unit]
      Description="Nomad Client Agent"
      Documentation=https://developer.hashicorp.com/
      After=network-online.target podman.service
      Wants=network-online.target
      Wants=consul.service
      After=consul.service
      Before=umount.target
      Conflicts=umount.target

      ConditionFileNotEmpty=${custom_bin_dir}/nomad
      ConditionFileNotEmpty=${nomad_config_dir}/nomad.hcl
      ConditionPathIsDirectory=${nomad_data_dir}

      [Service]
      # https://developer.hashicorp.com/nomad/commands#environment-variables
      Environment="NOMAD_ADDR=https://127.0.0.1:4646"
      Environment="NOMAD_CACERT=${custom_root_ca_path}/SoloLab-Root-CA.pem"
      Environment="NOMAD_CLIENT_CERT=${nomad_config_dir}/client.pem"
      Environment="NOMAD_CLIENT_KEY=${nomad_config_dir}/client-key.pem"
      Environment="NOMAD_TOKEN=${nomad_acl_token}" 

      ExecReload=/bin/kill -HUP $MAINPID
      ExecStart=${custom_bin_dir}/nomad agent \
        -config ${nomad_config_dir}/nomad.hcl
      # https://discuss.hashicorp.com/t/issue-with-nomad-service-restart-node-not-eligible-after-bash-script-execution/63723
      ExecStartPost=/bin/bash -c "sleep $(shuf -i 30-40 -n 1) && ${custom_bin_dir}/nomad node eligibility -enable -self"
      ExecStop=${custom_bin_dir}/nomad node drain -enable -self
      KillMode=process
      KillSignal=SIGINT
      LimitNOFILE=65536
      LimitNPROC=infinity
      TasksMax=infinity
      Restart=on-failure
      RestartSec=2
      OOMScoreAdjust=-999

      [Install]
      WantedBy=multi-user.target
  - path: /tmp/install-mise.sh
    permissions: "0755"
    source:
      uri: ${mise_script_download_url}

# https://cloudinit.readthedocs.io/en/latest/reference/examples.html#update-apt-database-on-first-boot
package_update: true
# https://cloudinit.readthedocs.io/en/latest/reference/examples.html#run-apt-or-yum-upgrade
package_upgrade: true
package_reboot_if_required: true
packages:
  - bash-completion
  - git
  - podman
  - cockpit
  - cockpit-podman
  - java-25-openjdk-devel

# https://gist.github.com/corso75/582d03db6bb9870fbf6466e24d8e9be7
runcmd:
  - update-ca-trust

  - /usr/bin/bsdtar -xf "${custom_bin_dir}/consul_linux_amd64.zip" -C ${custom_bin_dir}
  - /usr/bin/rm "${custom_bin_dir}/consul_linux_amd64.zip"
  - /usr/bin/chmod +x ${custom_bin_dir}/consul
  - /usr/bin/chown root:root ${custom_bin_dir}/consul

  - /usr/bin/bsdtar -xf "${custom_bin_dir}/nomad_linux_amd64.zip" -C ${custom_bin_dir}
  - /usr/bin/rm "${custom_bin_dir}/nomad_linux_amd64.zip"
  - /usr/bin/chmod +x ${custom_bin_dir}/nomad
  - /usr/bin/chown root:root ${custom_bin_dir}/nomad

  - /usr/bin/bsdtar -xf "${custom_bin_dir}/nomad-driver-podman_linux_amd64.zip" -C ${custom_bin_dir}
  - /usr/bin/rm "${custom_bin_dir}/nomad-driver-podman_linux_amd64.zip"
  - /usr/bin/chmod +x ${custom_bin_dir}/nomad-driver-podman
  - /usr/bin/chown root:root ${custom_bin_dir}/nomad-driver-podman

  - systemctl enable --now consul.service
  - systemctl enable --now podman.socket
  - systemctl enable --now nomad.service

  # https://access.redhat.com/solutions/4661741
  # - sudo -u podmgr /bin/bash -c "export XDG_RUNTIME_DIR=/run/user/$(id -u podmgr); /usr/bin/systemctl enable --now podman.socket --user"
  # https://stackoverflow.com/questions/34167257/can-i-control-a-user-systemd-using-systemctl-user-after-sudo-su-myuser
  - systemctl --user --machine=podmgr@.host enable podman.socket --now
  - systemctl stop firewalld
